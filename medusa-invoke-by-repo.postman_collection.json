            "url": {
              "raw": "{{MERCUR_API_BASE_URL}}/store/carts/{{cart_id}}",
              "host": ["{{MERCUR_API_BASE_URL}}"],
              "path": ["store", "carts", "{{cart_id}}"]
            }
          }
        },

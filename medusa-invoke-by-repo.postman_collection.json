    "description": "Collection generated from codebase usage. Targets Medusa backend endpoints under MERCUR_API_BASE_URL (store APIs) that are invoked by this repository.\n\nVariables:\n- MERCUR_API_BASE_URL (e.g. http://localhost:9000)\n- MERCUR_PUBLISHABLE_API_KEY\n- cart_id, line_item_id, payment_collection_id, region_id, country_code, variant_id, order_id, product_id, address_id, q, limit, offset\n\nNotes:\n- Most /store/* endpoints require x-publishable-api-key.\n- Customer endpoints may also require auth (cookie/session/JWT) depending on backend config; use Authorization header variables if needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "MERCUR_API_BASE_URL", "value": "http://localhost:9000" },
    { "key": "MERCUR_PUBLISHABLE_API_KEY", "value": "" },
    { "key": "cart_id", "value": "" },
    { "key": "line_item_id", "value": "" },
    { "key": "payment_collection_id", "value": "" },
    { "key": "region_id", "value": "" },
    { "key": "country_code", "value": "my" },
    { "key": "variant_id", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "address_id", "value": "" },
    { "key": "q", "value": "iphone" },
    { "key": "limit", "value": "10" },
    { "key": "offset", "value": "0" },
    { "key": "fields", "value": "id,title,handle,thumbnail,variants" },
    { "key": "customer_token", "value": "" }
  ],
  "item": [
    {
      "name": "Carts",
      "item": [
        {
          "name": "Create cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-publishable-api-key", "value": "{{MERCUR_PUBLISHABLE_API_KEY}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{MERCUR_API_BASE_URL}}/store/carts", "host": ["{{MERCUR_API_BASE_URL}}"], "path": ["store", "carts"] },
            "body": { "mode": "raw", "raw": "{\n  \"region_id\": \"{{region_id}}\",\n  \"country_code\": \"{{country_code}}\"\n}" }
          }
        },
        {
          "name": "Get cart",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-publishable-api-key", "value": "{{MERCUR_PUBLISHABLE_API_KEY}}" }

            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address\": {\n    \"first_name\": \"Test\",\n    \"last_name\": \"User\",\n    \"address_1\": \"123 Main St\",\n    \"city\": \"Kuala Lumpur\",\n    \"country_code\": \"{{country_code}}\",\n    \"postal_code\": \"50000\",\n    \"phone\": \"+60123456789\"\n  }\n}"
